{
  "name": "factcheck-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "worker"
  ],
  "scripts": {
    "dev:web": "vite",
    "dev:worker": "npm --prefix worker run dev",
    "dev": "concurrently -k \"npm run dev:web\" \"npm run dev:worker\"",
    "build": "tsc -b && vite build",
    "build:worker": "npm --prefix worker run deploy -- --dry-run",
    "lint": "eslint .",
    "test": "npm run test:worker",
    "test:web": "vitest run",
    "test:worker": "npm --prefix worker run test",
    "preview": "vite preview"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "concurrently": "^9.2.1",
    "vitest": "^3.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
